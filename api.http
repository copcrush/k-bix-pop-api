### Variables
# Nest `main.ts` uses global prefix `api`
@baseUrl = http://localhost:8888/api
@email = test_user@example.com
@password = supersecurepassword123
# The access token is populated automatically when you run the Login request
@accessToken = {{login.response.body.accessToken}}

### 1. Register a new User
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}",
  "firstName": "John",
  "lastName": "Doe"
}

### 2. Login User
# @name login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}"
}

### 3. Refresh Access Token (Uses HttpOnly Cookie automatically)
POST {{baseUrl}}/auth/refresh
Content-Type: application/json
# The refresh_token cookie set during login will be automatically included by standard HTTP clients.

### 4. Logout User
POST {{baseUrl}}/auth/logout
Content-Type: application/json
Authorization: Bearer {{accessToken}}

### 5. Get All Users
GET {{baseUrl}}/users
Content-Type: application/json
